{
  "env": {
    "browser": true,
    "es2021": true
  },
  "extends": [
    "airbnb-base"
  ],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "no-console": "warn",
    "no-alert": "warn",
    "prefer-const": "error",
    "arrow-body-style": ["error", "as-needed"],
    "no-unused-vars": ["error", { "argsIgnorePattern": "^_" }],
    "class-methods-use-this": "off",
    "import/prefer-default-export": "off"
  },
  "globals": {
    "document": "readonly",
    "window": "readonly",
    "localStorage": "readonly"
  }
}
